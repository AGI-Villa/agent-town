# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# OpenRouter (LLM API for social feed generation)
OPENROUTER_API_KEY=your_openrouter_api_key

# Admin API Key (protects LLM generation & watcher control endpoints)
# If not set, these endpoints are open (fine for local dev)
# ADMIN_API_KEY=your_random_secret_here

# OpenClaw Home (auto-discovery reads agents from here)
# Default: ~/.openclaw
# OPENCLAW_HOME=~/.openclaw

# Workspace Configuration (JSON string)
# Example: {"workspaces":[{"id":"team-a","name":"Team Alpha","agentIds":["cto","dev-lead"]},{"id":"team-b","name":"Team Beta","agentIds":["cpo","uiux"]}],"defaultWorkspaceId":"team-a"}
# WORKSPACE_CONFIG=
